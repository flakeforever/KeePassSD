<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Raised Circular Surface -->
    <!-- Top-left highlight -->
    <path
        android:pathData="M54,18 A36,36 0 1 0 54,90 A36,36 0 1 0 54,18 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="18"
                android:startY="18"
                android:endX="90"
                android:endY="90"
                android:type="linear">
                <item android:offset="0" android:color="#FFFFFF" />
                <item android:offset="1" android:color="#D1D9E6" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Bottom-right shadow -->
    <path
        android:pathData="M54,22 A32,32 0 1 0 54,86 A32,32 0 1 0 54,22 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="22"
                android:startY="22"
                android:endX="86"
                android:endY="86"
                android:type="linear">
                <item android:offset="0" android:color="#D1D9E6" />
                <item android:offset="1" android:color="#A2B1C6" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Main Button Surface -->
    <path
        android:fillColor="#D1D9E6"
        android:pathData="M54,24 A30,30 0 1 0 54,84 A30,30 0 1 0 54,24 Z" />

    <!-- ==========================================
         ENGRAVED KEY (蚀刻 / 版刻) - Rotated -45°
         Inset Bevel: highlight on bottom-right,
         shadow on top-left, dark floor in center.
         ========================================== -->
    <group
        android:rotation="-45"
        android:pivotX="54"
        android:pivotY="54">

        <!-- ====== INSET BEVEL LAYER 1: Bottom-right Highlight ====== -->
        <!-- Offset (+1.5, +1.5) - peeks out at bottom-right edge     -->
        <!-- Head highlight -->
        <path
            android:fillColor="#FFFFFF"
            android:alpha="0.7"
            android:pathData="M55.5,29.5 A12,12 0 1 1 55.5,53.5 A12,12 0 1 1 55.5,29.5 Z" />
        <!-- Shaft + teeth highlight -->
        <path
            android:fillColor="#FFFFFF"
            android:alpha="0.7"
            android:pathData="M52.5,50.5 L58.5,50.5 L58.5,60.5 L64.5,60.5 L64.5,65.5 L58.5,65.5 L58.5,69.5 L62.5,69.5 L62.5,74.5 L58.5,74.5 L58.5,78.5 L52.5,78.5 Z" />

        <!-- ====== INSET BEVEL LAYER 2: Top-left Shadow ====== -->
        <!-- Offset (-1.5, -1.5) - peeks out at top-left edge   -->
        <!-- Head shadow -->
        <path
            android:fillColor="#5A6A7A"
            android:pathData="M52.5,26.5 A12,12 0 1 1 52.5,50.5 A12,12 0 1 1 52.5,26.5 Z" />
        <!-- Shaft + teeth shadow -->
        <path
            android:fillColor="#5A6A7A"
            android:pathData="M49.5,47.5 L55.5,47.5 L55.5,57.5 L61.5,57.5 L61.5,62.5 L55.5,62.5 L55.5,66.5 L59.5,66.5 L59.5,71.5 L55.5,71.5 L55.5,75.5 L49.5,75.5 Z" />

        <!-- ====== INSET BEVEL LAYER 3: Dark Engraved Floor ====== -->
        <!-- Exact position - covers center, leaving bevel edges   -->
        <!-- Head floor -->
        <path
            android:fillColor="#1A1A2E"
            android:pathData="M54,28 A12,12 0 1 1 54,52 A12,12 0 1 1 54,28 Z" />
        <!-- Shaft + teeth floor -->
        <path
            android:fillColor="#1A1A2E"
            android:pathData="M51,49 L57,49 L57,59 L63,59 L63,64 L57,64 L57,68 L61,68 L61,73 L57,73 L57,77 L51,77 Z" />

        <!-- ====== LAYER 4: Key Head Hole (punch-through) ====== -->
        <!-- Slightly darker than surface to show inner recess    -->
        <path
            android:fillColor="#B8C4D4"
            android:pathData="M54,35 A5,5 0 1 1 54,45 A5,5 0 1 1 54,35 Z" />

        <!-- Hole inner highlight (bottom-right light catching) -->
        <path
            android:fillColor="#FFFFFF"
            android:alpha="0.3"
            android:pathData="M55,36 A5,5 0 1 1 55,46 A5,5 0 1 1 55,36 Z" />

        <!-- Hole inner shadow (top-left) -->
        <path
            android:fillColor="#6A7A8A"
            android:pathData="M53,34 A5,5 0 1 1 53,44 A5,5 0 1 1 53,34 Z" />

        <!-- Hole surface color to finish the punch -->
        <path
            android:fillColor="#C0C8D8"
            android:pathData="M54,35 A4.5,4.5 0 1 1 54,44 A4.5,4.5 0 1 1 54,35 Z" />

    </group>

</vector>